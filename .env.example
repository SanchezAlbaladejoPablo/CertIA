# ============================================================
# CertIA — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ============================================================

# --- BASE DE DATOS (MySQL / TiDB Cloud) ---
DATABASE_URL=mysql://user:password@host:4000/certia

# --- AUTENTICACIÓN JWT ---
# Genera una clave con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# --- STRIPE ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_ENTERPRISE=price_...

# --- OPENAI (Opcional — si vacío usa sugerencias estáticas) ---
OPENAI_API_KEY=

# --- ENTORNO ---
NODE_ENV=production
PORT=3000
