# ============================================================
# CertIA — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ============================================================

# --- Base de datos (TiDB / MySQL) ---
DATABASE_URL=mysql://user:password@host:4000/certia

# --- Autenticación (Manus OAuth) ---
MANUS_CLIENT_ID=
MANUS_CLIENT_SECRET=
MANUS_REDIRECT_URI=https://tudominio.com/auth/callback

# --- Stripe (pagos y suscripciones) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# --- OpenAI (sugerencias de circuitos con IA) ---
OPENAI_API_KEY=sk-...

# --- Cloudflare R2 (almacenamiento de PDFs firmados) ---
# Crear bucket en: https://dash.cloudflare.com → R2
# Crear token API con permisos Object Read & Write
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=certia-signed-docs
R2_PUBLIC_URL=https://docs.certia.es

# --- Email transaccional (SMTP) ---
# Proveedores recomendados: Resend (smtp.resend.com), SendGrid, Postmark
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_...
SMTP_FROM=noreply@certia.es

# --- Analytics (Umami, opcional) ---
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# --- Entorno ---
NODE_ENV=production
PORT=3000
